generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Aura enums ──

enum AuraOtpPurpose {
  REGISTER_PHONE
  LOGIN_PHONE
  RESET_PASSWORD
  CHANGE_PHONE
  SENSITIVE_ACTION
}

enum AuraOutboxStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
}

enum AuraJobRunStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

// ── Aura auth core ──

model AuraUser {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  disabledAt     DateTime?
  deletedAt      DateTime?
  sessionVersion Int      @default(1)

  email       String? @unique
  displayName String?
  isAdmin     Boolean @default(false)
  isBlocked   Boolean @default(false)
  whatsappLinked   Boolean @default(false)
  whatsappE164     String?
  linkCode         String?
  linkCodeExpiresAt DateTime?

  // Aura relations
  phoneIdentities    AuraPhoneIdentity[]
  passwordCredential AuraPasswordCredential?
  sessions           AuraSession[]
  notifications      AuraNotification[]
  auditLogs          AuraAuditLog[]
  profile            Profile?
}

model AuraPhoneIdentity {
  id                 String    @id @default(cuid())
  userId             String
  countryCode        String
  nationalNumber     String
  phoneE164          String    @unique
  verifiedAt         DateTime?
  whatsappVerifiedAt DateTime?
  linkCode           String?
  linkCodeExpiresAt  DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  user               AuraUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([phoneE164])
  @@index([linkCode])
}

model AuraPasswordCredential {
  id           String   @id @default(cuid())
  userId       String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         AuraUser @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuraOtpChallenge {
  id          String         @id @default(cuid())
  userId      String?
  phoneE164   String
  purpose     AuraOtpPurpose
  codeHash    String
  expiresAt   DateTime
  consumedAt  DateTime?
  attempts    Int            @default(0)
  maxAttempts Int            @default(5)
  metadata    Json?
  sentAt      DateTime?
  createdAt   DateTime       @default(now())

  @@index([phoneE164, purpose])
  @@index([userId])
  @@index([expiresAt])
}

model AuraSession {
  id             String    @id @default(cuid())
  tokenHash      String    @unique
  csrfTokenHash  String
  userId         String
  expiresAt      DateTime
  revokedAt      DateTime?
  lastUsedAt     DateTime  @default(now())
  userAgentHash  String?
  ipHash         String?
  sessionVersion Int       @default(1)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           AuraUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model AuraRateLimitBucket {
  key       String   @id
  count     Int      @default(0)
  resetAt   DateTime
  updatedAt DateTime @updatedAt
}

model AuraNotification {
  id              String    @id @default(cuid())
  name            String
  recipientUserId String?
  title           String
  body            String
  payload         Json?
  readAt          DateTime?
  createdAt       DateTime  @default(now())
  recipient       AuraUser? @relation(fields: [recipientUserId], references: [id], onDelete: Cascade)

  @@index([recipientUserId, readAt, createdAt])
  @@index([name])
}

model AuraOutboxEvent {
  id          String           @id @default(cuid())
  type        String
  payload     Json
  status      AuraOutboxStatus @default(PENDING)
  attempts    Int              @default(0)
  maxAttempts Int              @default(5)
  nextRunAt   DateTime         @default(now())
  lockedAt    DateTime?
  processedAt DateTime?
  error       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([status, nextRunAt])
  @@index([type])
}

model AuraJobRun {
  id            String           @id @default(cuid())
  jobName       String
  operationName String?
  input         Json?
  status        AuraJobRunStatus
  requestId     String?
  attempts      Int              @default(1)
  maxAttempts   Int              @default(3)
  metadata      Json?
  error         String?
  lastError     String?
  runAt         DateTime?
  lockedUntil   DateTime?
  startedAt     DateTime         @default(now())
  finishedAt    DateTime?
  completedAt   DateTime?
  createdAt     DateTime         @default(now())

  @@index([jobName, startedAt])
  @@index([status])
  @@index([status, runAt])
  @@index([operationName])
}

model AuraAuditLog {
  id          String    @id @default(cuid())
  actorUserId String?
  action      String
  operation   String?
  requestId   String?
  source      String
  metadata    Json?
  createdAt   DateTime  @default(now())
  actor       AuraUser? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
  @@index([requestId])
}

model AuraFile {
  id        String   @id @default(cuid())
  name      String
  key       String   @unique
  url       String
  mimeType  String
  size      Int
  prefix    String
  storage   String   @default("filesystem")
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([prefix])
  @@index([storage])
}

// ── Aura enhanced storage (Decision 17) ──

model AuraStoredFile {
  id          String   @id @default(cuid())
  filename    String
  contentType String
  size        Int
  path        String   @unique
  driver      String   @default("filesystem")
  uploadedBy  String?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([driver])
  @@index([uploadedBy])
}

// ── Aura workflow runs (Decision 22) ──

enum AuraWorkflowStatus {
  PENDING
  RUNNING
  SLEEPING
  COMPLETED
  FAILED
  CANCELLED
}

model AuraWorkflowRun {
  id              String             @id @default(cuid())
  workflowName    String
  input           Json
  status          AuraWorkflowStatus @default(PENDING)
  currentStep     String?
  completedSteps  Json               @default("[]")
  error           String?
  startedAt       DateTime           @default(now())
  completedAt     DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([workflowName, status])
  @@index([status])
}

// ── Aura AI agent state (Decision 27) ──

enum AuraAgentThreadStatus {
  ACTIVE
  ARCHIVED
}

model AuraAgentThread {
  id        String                @id @default(cuid())
  agentName String
  userId    String?
  title     String?
  metadata  Json?
  status    AuraAgentThreadStatus  @default(ACTIVE)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  messages  AuraAgentMessage[]

  @@index([agentName, userId])
  @@index([userId, updatedAt])
}

model AuraAgentMessage {
  id           String          @id @default(cuid())
  threadId     String
  role         String
  content      String
  toolCalls    Json?
  toolResults  Json?
  metadata     Json?
  createdAt    DateTime        @default(now())
  thread       AuraAgentThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

model AuraAIUsage {
  id            String   @id @default(cuid())
  agentName     String
  threadId      String?
  userId        String?
  model         String
  provider      String
  inputTokens   Int
  outputTokens  Int
  totalTokens   Int
  latencyMs     Int
  estimatedCost Float?
  createdAt     DateTime @default(now())

  @@index([agentName, createdAt])
  @@index([userId, createdAt])
  @@index([threadId, createdAt])
}

// ── Application: Vibe Platform ──

enum ProfileLanguage {
  FR
  EN
}

enum ProfileStatus {
  ACTIVE
  SUSPENDED
}

enum ServiceAvailability {
  AVAILABLE
  BUSY
  UNAVAILABLE
}

enum MatchStatus {
  PENDING
  ACCEPTED
  REFUSED
  CANCELLED
  EXPIRED
}

enum ConversationStatus {
  OPEN
  CLOSED
  DISPUTED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  DISMISSED
}

enum DisputeDecision {
  DISMISS
  WARN_REPORTER
  WARN_REPORTED
  WARN_BOTH
  SUSPEND_REPORTED
  SUSPEND_BOTH
}

enum WhatsappDirection {
  IN
  OUT
}

enum WhatsappOutboxStatus {
  PENDING
  SENDING
  SUCCEEDED
  FAILED
}

enum PaymentKind {
  BADGE
  BOOST
  PRO
  COMMISSION
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum SubscriptionPlan {
  BASIC
  PRO
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum BoostSlotStatus {
  ACTIVE
  EXPIRED
}

enum KnowledgeEntityType {
  SKILL
  LOCATION
  INDUSTRY
  NEED
  SERVICE
  USER
}

enum KnowledgeEntityStatus {
  ACTIVE
  PENDING_REVIEW
}

enum KnowledgeSource {
  CONVERSATION
  DASHBOARD
}

enum KnowledgeRelationPredicate {
  PROVIDES
  REQUIRES
  LOCATED_IN
  LOOKS_FOR
  MATCHES
  CONNECTED_TO
  RATED
}

model Profile {
  id            String          @id @default(cuid())
  userId        String          @unique
  displayName   String?
  bio           String?
  photoFileId   String?
  locationLabel String?
  lat           Float?
  lng           Float?
  language      ProfileLanguage @default(FR)
  isProvider    Boolean         @default(false)
  isClient      Boolean         @default(false)
  isVerified    Boolean         @default(false)
  verifiedAt    DateTime?
  warningCount  Int             @default(0)
  status        ProfileStatus   @default(ACTIVE)
  alias         String          @unique
  consent       Json?
  ratingAvg     Float?
  ratingCount   Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  user          AuraUser        @relation(fields: [userId], references: [id], onDelete: Cascade)

  services      Service[]
  matchesAsRequester Match[]    @relation("MatchRequester")
  matchesAsTarget    Match[]    @relation("MatchTarget")
  ratingsGiven  Rating[]       @relation("RaterProfile")
  ratingsReceived Rating[]     @relation("RateeProfile")
  disputes      Dispute[]

  @@index([userId])
  @@index([status])
  @@index([alias])
}

model Service {
  id           String              @id @default(cuid())
  userId       String
  title        String
  description  String
  priceXaf     Int
  availability ServiceAvailability @default(AVAILABLE)
  zone         String?
  isActive     Boolean             @default(true)
  deletedAt    DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  profile      Profile             @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId, isActive])
  @@index([isActive])
}

model Match {
  id              String      @id @default(cuid())
  requesterId     String
  targetId        String
  status          MatchStatus @default(PENDING)
  originSessionId String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  requester       Profile     @relation("MatchRequester", fields: [requesterId], references: [userId], onDelete: Cascade)
  target          Profile     @relation("MatchTarget", fields: [targetId], references: [userId], onDelete: Cascade)
  conversation    Conversation?

  @@unique([requesterId, targetId, status])
  @@index([requesterId])
  @@index([targetId])
}

model Conversation {
  id        String             @id @default(cuid())
  userAId   String
  userBId   String
  matchId   String             @unique
  status    ConversationStatus @default(OPEN)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  match     Match              @relation(fields: [matchId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]
  ratings   Rating[]
  disputes  Dispute[]

  @@index([userAId])
  @@index([userBId])
}

model ChatMessage {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  readBy         Json         @default("[]")
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model Rating {
  id             String       @id @default(cuid())
  conversationId String
  raterId        String
  rateeId        String
  score          Int
  comment        String?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  rater          Profile      @relation("RaterProfile", fields: [raterId], references: [userId], onDelete: Cascade)
  ratee          Profile      @relation("RateeProfile", fields: [rateeId], references: [userId], onDelete: Cascade)

  @@unique([conversationId, raterId])
}

model Dispute {
  id             String         @id @default(cuid())
  conversationId String
  reporterId     String
  reason         String
  snapshot       Json
  status         DisputeStatus  @default(OPEN)
  decision       DisputeDecision?
  resolution     String?
  resolvedById   String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  conversation   Conversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  reporter       Profile        @relation(fields: [reporterId], references: [userId], onDelete: Cascade)

  @@index([status])
  @@index([conversationId])
}

model KnowledgeEntity {
  id          String                @id @default(cuid())
  userId      String
  type        KnowledgeEntityType
  value       String
  confidence  Float                 @default(0.5)
  status      KnowledgeEntityStatus @default(ACTIVE)
  source      KnowledgeSource       @default(CONVERSATION)
  metadata    Json?
  embeddingId String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  relations   KnowledgeRelation[]   @relation("SourceEntity")
  targetOf    KnowledgeRelation[]   @relation("TargetEntity")
  embedding   GraphEmbedding?

  @@index([userId, type])
  @@index([type, value])
  @@index([status])
}

model KnowledgeRelation {
  id        String                      @id @default(cuid())
  sourceId  String
  targetId  String
  predicate KnowledgeRelationPredicate
  strength  Float                       @default(0.5)
  source    KnowledgeSource             @default(CONVERSATION)
  createdAt DateTime                    @default(now())
  updatedAt DateTime                    @updatedAt
  sourceEntity KnowledgeEntity          @relation("SourceEntity", fields: [sourceId], references: [id], onDelete: Cascade)
  targetEntity KnowledgeEntity          @relation("TargetEntity", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId, predicate])
  @@index([sourceId])
  @@index([targetId])
  @@index([predicate])
  @@index([predicate, sourceId])
  @@index([predicate, targetId])
}

model GraphEmbedding {
  id        String          @id @default(cuid())
  entityId  String          @unique
  // embedding vector(1536) — added via raw SQL migration when pgvector is available
  metadata  Json?
  updatedAt DateTime        @updatedAt
  entity    KnowledgeEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)
}

model WhatsappInbox {
  id                String    @id @default(cuid())
  providerMessageId String    @unique
  phoneE164         String
  direction         WhatsappDirection @default(IN)
  payload           Json
  processedAt       DateTime?
  error             String?
  createdAt         DateTime  @default(now())

  @@index([phoneE164])
  @@index([processedAt])
}

model WhatsappOutbox {
  id             String              @id @default(cuid())
  idempotencyKey String              @unique
  phoneE164      String
  body           String
  status         WhatsappOutboxStatus @default(PENDING)
  attempts       Int                 @default(0)
  nextRunAt      DateTime            @default(now())
  lockedAt       DateTime?
  error          String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([status, nextRunAt])
}

model MatchSession {
  id              String   @id @default(cuid())
  requesterId     String
  query           String
  intent          String?
  candidatesGraph Json?
  candidatesVector Json?
  fusedTopN       Json?
  pickedId        String?
  latencyMs       Int?
  createdAt       DateTime @default(now())

  @@index([requesterId])
}

model Payment {
  id              String        @id @default(cuid())
  userId          String
  provider        String
  providerTransId String?       @unique
  kind            PaymentKind
  amountXaf       Int
  status          PaymentStatus @default(PENDING)
  metadata        Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([userId])
  @@index([status])
}

model Subscription {
  id        String             @id @default(cuid())
  userId    String
  plan      SubscriptionPlan   @default(BASIC)
  startsAt  DateTime           @default(now())
  endsAt    DateTime
  status    SubscriptionStatus @default(ACTIVE)
  paymentId String?
  createdAt DateTime           @default(now())

  @@index([userId, status])
}

model BoostSlot {
  id        String          @id @default(cuid())
  userId    String
  startsAt  DateTime        @default(now())
  endsAt    DateTime
  status    BoostSlotStatus @default(ACTIVE)
  paymentId String?
  createdAt DateTime        @default(now())

  @@index([userId, status])
}

// ── Application: Todo ──

enum TodoStatus {
  PENDING
  IN_PROGRESS
  DONE
}

enum TodoPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Todo {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      TodoStatus   @default(PENDING)
  priority    TodoPriority @default(MEDIUM)
  dueDate     DateTime?
  userId      String?
  aiGenerated Boolean      @default(false)
  metadata    Json?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([userId, status])
  @@index([status, createdAt])
}
