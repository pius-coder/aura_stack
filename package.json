  "scripts": {
    "dev": "prisma generate && concurrently -n vite,broadcast -c blue,magenta \"vite dev --port 3000 --host\" \"bun src/aura/server/broadcast.ts\"",
    "dev:vite": "vite dev --port 3000",
    "build": "prisma generate && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "aura:make": "bun src/aura/cli/make.ts",
    "aura:codegen": "bun src/aura/cli/codegen.ts",
    "aura:doctor": "bun src/aura/cli/doctor.ts",
    "aura:cron": "bun src/aura/cli/cron.ts",
    "aura:outbox": "bun src/aura/cli/outbox.ts",
    "aura:broadcast": "bun src/aura/server/broadcast.ts"
  },
